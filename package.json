{
  "name": "vrshell",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "scripts": {
    "install:frontend": "npm --prefix frontend install",
    "dev": "npm --prefix frontend run dev",
    "typecheck": "npm --prefix frontend run typecheck",
    "test:frontend": "npm --prefix frontend run test",
    "build": "npm --prefix frontend run build",
    "preview": "npm --prefix frontend run preview",
    "lint": "npm --prefix frontend run lint",
    "format": "npm --prefix frontend run format",
    "format:check": "npm --prefix frontend run format:check",
    "test:e2e": "npm --prefix frontend run test:e2e",
    "test:e2e:smoke": "npm --prefix frontend run test:e2e:smoke",
    "check:json": "node scripts/check-json.mjs",
    "check:utf8": "node scripts/check-utf8.mjs",
    "generate:ipc": "node scripts/generate-ipc-contract.mjs",
    "check:ipc": "node scripts/generate-ipc-contract.mjs --check",
    "audit:frontend": "node scripts/npm-audit-summary.mjs",
    "rust:check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "rust:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "rust:fmt:check": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "rust:test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "rust:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
    "rust:audit": "cargo audit --manifest-path src-tauri/Cargo.toml",
    "security:audit": "npm run audit:frontend && npm run rust:audit",
    "check": "npm run check:ipc && npm run check:json && npm run check:utf8 && npm run lint && npm run typecheck && npm run test:frontend && npm run rust:check && npm run rust:test && npm run rust:clippy",
    "tauri:dev": "npm --prefix frontend run tauri",
    "tauri:build": "npm --prefix frontend run tauri:build"
  }
}
